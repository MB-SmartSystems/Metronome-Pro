'use client';

import { useEffect, useRef, useState } from 'react';

interface UseSmoothPulseOptions {
  isActive: boolean;
  duration?: number; // Duration in milliseconds
  maxOpacity?: number;
  minOpacity?: number;
}

/**
 * Custom hook for smooth 60fps pulse animation using requestAnimationFrame
 * Replaces CSS animate-pulse for better performance and smoothness
 */
export function useSmoothPulse({
  isActive,
  duration = 600,
  maxOpacity = 1,
  minOpacity = 0.4,
}: UseSmoothPulseOptions) {
  const [opacity, setOpacity] = useState(maxOpacity);
  const animationFrameRef = useRef<number>();
  const startTimeRef = useRef<number>();
  const isIncreasingRef = useRef(true);

  useEffect(() => {
    if (!isActive) {
      if (animationFrameRef.current) {
        cancelAnimationFrame(animationFrameRef.current);
      }
      setOpacity(maxOpacity);
      startTimeRef.current = undefined;
      return;
    }

    const animate = (timestamp: number) => {
      if (!startTimeRef.current) {
        startTimeRef.current = timestamp;
        setOpacity(maxOpacity); // CRITICAL: Immediate full opacity on beat start
      }

      const elapsed = timestamp - startTimeRef.current;
      const progress = (elapsed % duration) / duration;

      // CRITICAL: Faster, more responsive animation curve
      let currentProgress: number;
      if (progress <= 0.3) {
        // First 30%: stay at max opacity (stronger beat indication)
        currentProgress = 0;
      } else if (progress <= 0.7) {
        // Next 40%: fade out quickly
        currentProgress = (progress - 0.3) / 0.4;
      } else {
        // Final 30%: fade back in
        currentProgress = 1 - ((progress - 0.7) / 0.3);
      }

      // Sharp easing for immediate visual feedback
      const eased = currentProgress < 0.5 
        ? 4 * currentProgress * currentProgress * currentProgress
        : 1 - Math.pow(-2 * currentProgress + 2, 3) / 2;

      const newOpacity = minOpacity + (maxOpacity - minOpacity) * (1 - eased);
      setOpacity(newOpacity);

      if (isActive) {
        animationFrameRef.current = requestAnimationFrame(animate);
      }
    };

    animationFrameRef.current = requestAnimationFrame(animate);

    return () => {
      if (animationFrameRef.current) {
        cancelAnimationFrame(animationFrameRef.current);
      }
    };
  }, [isActive, duration, maxOpacity, minOpacity]);

  return opacity;
}